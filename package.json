{
  "name": "portfolio-website",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-ready portfolio website for Sai Karthik Kagolanu",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit": "npm audit --audit-level=moderate",
    "size": "size-limit",
    "ci": "npm run type-check && npm run test:coverage && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "size-limit": [
    {
      "path": ".next/static/**/*.js",
      "limit": "200 KB"
    }
  ],
  "keywords": [
    "portfolio",
    "nextjs",
    "ml-engineer",
    "robotics"
  ],
  "author": "Sai Karthik Kagolanu",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.5.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.12.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/preset-app": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^18.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-storybook": "^10.4.6",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "pdf2json": "^4.0.3",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "serve": "^14.2.6",
    "storybook": "^10.4.6",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "rimraf": "^6.0.1",
    "glob": "^11.0.0",
    "inflight": "npm:@zkochan/inflight@^2.0.0"
  }
}
