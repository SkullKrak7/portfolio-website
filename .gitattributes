# Normalize all text files to LF in the repo and working tree.
# Overrides core.autocrlf so Windows checkouts don't flip LF<->CRLF
# (which is what produced the "LF will be replaced by CRLF" warnings).
* text=auto eol=lf

# Binary assets — never normalize or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
